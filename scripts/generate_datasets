import numpy as np

from src.data.synthetic_generator import (
    SEED,
    run_baseline,
    run_axis1,
    run_axis2,
    run_axis3,
    run_axis4,
    run_axis5,
)


def main() -> None:
    np.random.seed(SEED)

    run_baseline()
    run_axis1()
    run_axis2()
    run_axis3()
    run_axis4()
    run_axis5()


if __name__ == "__main__":
    main()
